<Window x:Class="LectorHuellas.Shared.Controls.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de Serex Lector" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" BorderThickness="0" 
                    Content="✕" Foreground="{DynamicResource TextSecondaryBrush}"
                    FontSize="18" Cursor="Hand" Click="Close_Click"/>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                <Border Width="80" Height="80" CornerRadius="20" Background="{StaticResource PrimaryBrush}" Margin="0,0,0,16">
                    <TextBlock Text="👆" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="BioCheck - Serex" FontSize="28" FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="v2.1.0" FontSize="14" Foreground="{StaticResource PrimaryLightBrush}" 
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="Sistema Biométrico de Control de Asistencia" 
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" 
                           TextAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Solución integral para el registro y gestión de presencia laboral mediante tecnología de reconocimiento dactilar de alta precisión." 
                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" 
                           TextAlignment="Center" TextWrapping="Wrap" Opacity="0.9"/>
            </StackPanel>

            <!-- Details -->
            <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Desarrollado por:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Departamento TIC" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Organización:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Grupo Serex" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Tecnología:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="WPF / .NET / MySQL" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Grid>
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,8"/>
                    <TextBlock Text="© 2026 Grupo Serex. Todos los derechos reservados." 
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <Button Grid.Row="3" Style="{StaticResource PrimaryButton}" 
                    Content="Cerrar" Width="120" HorizontalAlignment="Center" 
                    Margin="0,20,0,0" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
