<Window x:Class="LectorHuellas.Shared.Controls.DocumentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guía de Usuario" 
        Height="650" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDarkBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="30,24" Background="{DynamicResource BgCardBrush}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📖" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Documentación de Usuario" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="ContextTitle" Text="Guía Rápida" FontSize="12" Foreground="{StaticResource PrimaryLightBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content Viewer -->
        <FlowDocumentScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <FlowDocument x:Name="DocViewer" FontFamily="Segoe UI" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" PagePadding="40,20">
                <!-- Content will be injected via code-behind -->
            </FlowDocument>
        </FlowDocumentScrollViewer>

        <!-- Footer / Status -->
        <Border Grid.Row="2" Padding="20,16" Background="{DynamicResource BgSurfaceBrush}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
            <Button Style="{StaticResource PrimaryButton}" Content="Entendido" HorizontalAlignment="Right" Width="120" Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
