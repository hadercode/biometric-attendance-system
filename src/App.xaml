<Application x:Class="LectorHuellas.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Shared/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:StringMatchConverter x:Key="StringMatchConverter"/>
            <conv:PageVisibilityConverter x:Key="PageVisConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisConverter"/>
            <conv:NotEmptyToVisibilityConverter x:Key="NotEmptyToVisConverter"/>
            <conv:HasValueConverter x:Key="HasValueConverter"/>
            <conv:BoolToTextConverter x:Key="BoolToTextConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
