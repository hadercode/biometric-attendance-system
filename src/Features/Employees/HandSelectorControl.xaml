<UserControl x:Class="LectorHuellas.Features.Employees.HandSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="FingerButton" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,16,16" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="12" Padding="20,16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
        <StackPanel>
            <TextBlock Text="Seleccione un dedo para registrar" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Hand -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="🤚 Mano Izquierda" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnLeftPinky" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="0">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Meñiq."/></TextBlock>
                        </Button>
                        <Button x:Name="BtnLeftRing" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="1" Margin="3,-8,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Anular"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnLeftMiddle" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="2" Margin="3,-14,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Medio"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnLeftIndex" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="3" Margin="3,-8,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Índice"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnLeftThumb" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="4" Margin="3,8,3,3" Height="60">
                            <TextBlock TextAlignment="Center"><Run Text="👍"/><LineBreak/><Run Text="Pulgar"/></TextBlock>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="1" Width="1" Background="{DynamicResource BorderBrush}" Margin="0,20,0,0"/>

                <!-- Right Hand -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Mano Derecha 🤚" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnRightThumb" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="5" Margin="3,8,3,3" Height="60">
                            <TextBlock TextAlignment="Center"><Run Text="👍"/><LineBreak/><Run Text="Pulgar"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnRightIndex" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="6" Margin="3,-8,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Índice"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnRightMiddle" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="7" Margin="3,-14,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Medio"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnRightRing" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="8" Margin="3,-8,3,3">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Anular"/></TextBlock>
                        </Button>
                        <Button x:Name="BtnRightPinky" Style="{StaticResource FingerButton}"
                                Click="FingerButton_Click" Tag="9">
                            <TextBlock TextAlignment="Center"><Run Text="🖐"/><LineBreak/><Run Text="Meñiq."/></TextBlock>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Selected finger indicator -->
            <TextBlock x:Name="SelectedFingerText" FontSize="13" Foreground="{StaticResource PrimaryLightBrush}"
                       HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="SemiBold"/>

            <!-- Enrolled count -->
            <TextBlock x:Name="EnrolledCountText" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
