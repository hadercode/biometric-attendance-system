<UserControl x:Class="LectorHuellas.Features.Employees.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LectorHuellas.Features.Employees"
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters">

    <Grid Margin="32,24">
        <Grid.Resources>
            <Style x:Key="FilterInputBorder" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BgDarkBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="Height" Value="38"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Empleados" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Administre los empleados registrados en el sistema"
                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.NewEmployeeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Empleado" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"
                        Content="🔄 Actualizar"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══ Filters ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="12" 
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" 
                Padding="16,12" Margin="0,0,0,16" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Filtrar por Nombre" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Border Style="{StaticResource FilterInputBorder}" Width="250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" VerticalAlignment="Center" Margin="10,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding NameFilter, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                     Padding="0,0,8,0"
                                     Tag="Escriba un nombre..."/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Departamento" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox Style="{StaticResource ModernComboBox}" 
                              ItemsSource="{Binding Departments}"
                              SelectedValue="{Binding SelectedDepartmentId}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="Name"
                              Width="250" Height="38">
                    </ComboBox>
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SecondaryButton}" Height="38" Padding="16,0"
                            Command="{Binding ClearFiltersCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🧹" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Limpiar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Employee Table ═══ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,110,0,0">
            <Grid>
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding Employees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          CellStyle="{StaticResource ModernDataGridCell}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="60" IsReadOnly="True"/>
                        
                        <DataGridTemplateColumn Width="120">
                            <DataGridTemplateColumn.Header>
                                <Button Content="Cédula" Command="{Binding DataContext.SortCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="Code" Style="{StaticResource HeaderSortButton}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Employee.Code}" VerticalAlignment="Center" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <Button Content="Nombres" Command="{Binding DataContext.SortCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="FirstNames" Style="{StaticResource HeaderSortButton}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Employee.FirstNames}" VerticalAlignment="Center" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <Button Content="Apellidos" Command="{Binding DataContext.SortCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="LastNames" Style="{StaticResource HeaderSortButton}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Employee.LastNames}" VerticalAlignment="Center" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="180">
                            <DataGridTemplateColumn.Header>
                                <Button Content="Departamento" Command="{Binding DataContext.SortCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="Department" Style="{StaticResource HeaderSortButton}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Employee.Department.Name}" VerticalAlignment="Center" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="130">
                            <DataGridTemplateColumn.Header>
                                <Button Content="Ingreso" Command="{Binding DataContext.SortCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="HireDate" Style="{StaticResource HeaderSortButton}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Employee.HireDate, StringFormat='{}{0:dd/MM/yyyy}'}" VerticalAlignment="Center" Margin="10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" Style="{StaticResource SecondaryButton}"
                                                ToolTip="Editar" Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="🗑️" Style="{StaticResource DangerButton}"
                                                ToolTip="Eliminar" Padding="8,4" FontSize="11"
                                                Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" CornerRadius="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Cargando empleados..." Foreground="White" FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Pagination Footer ═══ -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12,8" 
                Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    <TextBlock Text="{Binding TotalRecords}" FontWeight="Bold" Margin="6,0,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                    <TextBlock Text="empleados" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButton}" 
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◀" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Anterior" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Padding="12,0" VerticalAlignment="Center" Background="{DynamicResource BgDarkBrush}" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Página" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" Margin="6,0" Foreground="{StaticResource PrimaryLightBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="de" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" Margin="6,0,0,0" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource SecondaryButton}" 
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            Padding="12,6" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Siguiente" VerticalAlignment="Center"/>
                            <TextBlock Text="▶" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
