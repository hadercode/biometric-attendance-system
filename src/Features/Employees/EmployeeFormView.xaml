<UserControl x:Class="LectorHuellas.Features.Employees.EmployeeFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters"
             xmlns:local="clr-namespace:LectorHuellas.Features.Employees">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="800">

            <!-- Header -->
            <TextBlock Text="{Binding FormTitle}" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- ═══ Form Card ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Información del Empleado" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <!-- Code (Cedula) -->
                    <TextBlock Text="Código / Cédula" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditing, Converter={StaticResource InverseBoolConverter}}"
                             Margin="0,0,0,16"/>

                    <!-- Names -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombres" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FirstNames, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Apellidos" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding LastNames, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Position -->
                    <TextBlock Text="Código Cargo (ccargo)" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Contact & Info -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Dirección" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Teléfono" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Dates -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fecha Nacimiento" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <DatePicker Style="{StaticResource ModernDatePicker}" SelectedDate="{Binding BirthDate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fecha Ingreso" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <DatePicker Style="{StaticResource ModernDatePicker}" SelectedDate="{Binding HireDate}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Message -->
                    <TextBlock Text="Mensaje Personalizado (Pantalla Asistencia)" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Master Data Grid -->
                    <Grid Grid.IsSharedSizeScope="True" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Gerencia -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Gerencia" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Managements}"
                                  SelectedValue="{Binding ManagementId, Mode=TwoWay}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"/>

                        <!-- Departamento -->
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Departamento" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Departments}"
                                  SelectedValue="{Binding DepartmentId, Mode=TwoWay}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"/>

                        <!-- Unidad -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Unidad" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox Grid.Row="4" Grid.Column="0" ItemsSource="{Binding Units}"
                                  SelectedValue="{Binding UnitId, Mode=TwoWay}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource ModernComboBox}"/>

                        <!-- Turno -->
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Turno" FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ComboBox Grid.Row="4" Grid.Column="2" ItemsSource="{Binding Shifts}"
                                  SelectedValue="{Binding ShiftId, Mode=TwoWay}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Description"
                                  Style="{StaticResource ModernComboBox}"/>
                    </Grid>

                    <!-- Photo Selection -->
                    <TextBlock Text="Foto del Empleado" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="60" Height="60" CornerRadius="30" Background="{DynamicResource BgSurfaceBrush}" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="👤" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                                Content="Seleccionar Foto..." Command="{Binding SelectPhotoCommand}"
                                Margin="16,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Hand Selector ═══ -->
            <local:HandSelectorControl x:Name="HandSelector" HorizontalAlignment="Center" Margin="0,0,0,24"
                                       SelectedFinger="{Binding SelectedFinger, Mode=TwoWay}"
                                       EnrolledFingers="{Binding EnrolledFingersList}"/>

            <!-- ═══ Fingerprint Capture Card ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Captura de Huella" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <!-- Real-time status -->
                        <TextBlock FontSize="13" Margin="0,0,0,16" TextWrapping="Wrap">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding CaptureStatusColor}"/>
                            </TextBlock.Foreground>
                            <TextBlock.Text>
                                <Binding Path="CaptureStatus"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <!-- Capture -->
                            <Button Style="{StaticResource PrimaryButton}"
                                    Command="{Binding CaptureFingerprintCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👆" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Capturar Huella" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Remove finger button -->
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RemoveFingerCommand}"
                                    Content="🗑️ Quitar dedo"
                                    ToolTip="Quitar la huella del dedo seleccionado"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Fingerprint Preview -->
                    <Border Grid.Column="1" Width="160" Height="200" CornerRadius="12"
                            Background="{DynamicResource BgSurfaceBrush}"
                            BorderThickness="2" BorderBrush="{DynamicResource BorderBrush}"
                            Margin="20,0,0,0">
                        <Grid>
                            <TextBlock Text="👆" FontSize="40" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.2"/>
                            <Image Source="{Binding FingerprintImage}" Stretch="Uniform" Margin="8"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ Validation ═══ -->
            <TextBlock Text="{Binding ValidationMessage}" FontSize="13"
                       Foreground="{StaticResource DangerBrush}" Margin="0,0,0,12"
                       Visibility="{Binding ValidationMessage, Converter={StaticResource NotEmptyToVisConverter}}"/>

            <!-- ═══ Action Buttons ═══ -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Cancelar"
                        Command="{Binding CancelCommand}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="💾 Guardar Empleado"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
