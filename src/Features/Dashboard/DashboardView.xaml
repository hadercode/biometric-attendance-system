<UserControl x:Class="LectorHuellas.Features.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="900">

            <!-- ═══ Clock Section ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTime}" FontSize="72" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" FontFamily="Consolas"/>
                    <TextBlock Text="{Binding CurrentDate}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ═══ Stats Cards ═══ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Employees -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="👥" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalEmployees}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryLightBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Total Empleados" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Present Today -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✅" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding PresentToday}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Presentes Hoy" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Absent Today -->
                <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="❌" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AbsentToday}" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource DangerBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Ausentes Hoy" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
