<UserControl x:Class="LectorHuellas.Features.Attendance.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1024">

    <Grid Background="{StaticResource BgDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>      <!-- Left: Main Stage -->
            <ColumnDefinition Width="380"/>    <!-- Right: Recent Activity -->
        </Grid.ColumnDefinitions>

        <!-- ═══ Navigation to Admin (Discreet) ═══ -->
        <Button Command="{Binding RequestAdminAccessCommand}"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="20" Padding="12,8" Panel.ZIndex="10"
                Style="{StaticResource SecondaryButton}"
                Background="Transparent" BorderThickness="0"
                Opacity="0.2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️" Margin="0,0,8,0"/>
                <TextBlock Text="Admin" FontSize="11"/>
            </StackPanel>
        </Button>

        <!-- ═══ LEFT PANEL: Stage ═══ -->
        <Grid Grid.Column="0">
            <!-- 1. Idle Background (Abstract shapes) -->
            <Path Data="M 0,0 L 300,0 L 0,300 Z" Fill="#086C5CE7" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            
            <!-- 2. Main Content (Clock & Status) -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Visibility="{Binding ShowCard, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="{Binding Source={x:Static System:DateTime.Now}, StringFormat='HH:mm'}" 
                               xmlns:System="clr-namespace:System;assembly=System.Runtime"
                               FontSize="160" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"
                               FontFamily="Segoe UI Light" Opacity="0.9"/>
                    
                    <Border CornerRadius="30" Padding="40,24" Background="#15FFFFFF" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👆" FontSize="32" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <TextBlock Text="Presione el botón para marcar" FontSize="24" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Style="{StaticResource PrimaryButton}" 
                            Command="{Binding CaptureAndIdentifyAsyncCommand}"
                            Width="300" Height="60" Margin="0,40,0,0">
                        <TextBlock Text="MARCAR ASISTENCIA" FontSize="18" FontWeight="Bold"/>
                    </Button>
                </StackPanel>

                <!-- 3. Identification Result Overlay -->
                <Border Width="500" Style="{StaticResource CardBorder}" 
                        Visibility="{Binding ShowCard, Converter={StaticResource BoolToVis}}"
                        Padding="0" ClipToBounds="True"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Height="10" Background="{StaticResource SuccessBrush}"/>

                        <Border Grid.Row="1" Padding="40">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Photo -->
                                    <Border Grid.Column="0" Width="120" Height="120" CornerRadius="60" 
                                            BorderThickness="4" BorderBrush="{StaticResource SuccessBrush}"
                                            Background="{StaticResource BgSurfaceBrush}" ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="👤" FontSize="70" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                       Opacity="0.3" Visibility="{Binding IdentifiedEmployee.PhotoPath, Converter={StaticResource NullToVisConverter}}"/>
                                            <Image Source="{Binding IdentifiedEmployee.PhotoPath}" Stretch="UniformToFill"
                                                   Visibility="{Binding IdentifiedEmployee.PhotoPath, Converter={StaticResource NotEmptyToVisConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AttendanceTypeBadge}" FontSize="12" FontWeight="Bold" 
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                        <TextBlock Text="{Binding IdentifiedEmployee.FullName}" FontSize="24" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding IdentifiedEmployee.Position}" FontSize="16" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="¡GRACIAS POR SU ASISTENCIA!" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,32,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══ RIGHT PANEL: Recent Activity Feed ═══ -->
        <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" 
                BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="24,32,24,20">
                    <StackPanel>
                        <TextBlock Text="HISTORIAL DE HOY" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Últimos 10 registros" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding RecentRecords}" Margin="24,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="16" Background="{StaticResource BgSurfaceBrush}" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Employee.FullName}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='hh:mm:ss tt'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Padding="8,4" CornerRadius="4" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{StaticResource SuccessColor}" Opacity="0.1"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
