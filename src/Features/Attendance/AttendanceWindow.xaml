<Window x:Class="LectorHuellas.Features.Attendance.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:attendance="clr-namespace:LectorHuellas.Features.Attendance"
        Title="Lector de Huellas — Control de Asistencia" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDarkBrush}">
    <Grid>
        <attendance:AttendanceView DataContext="{Binding AttendanceVM}"/>
        
        <!-- Floating Theme Toggle -->
        <Button Style="{StaticResource ThemeToggleButton}" 
                Command="{Binding ToggleThemeCommand}"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="20" Width="40" Height="40" Padding="0"
                ToolTip="Cambiar Tema (Claro/Oscuro)">
            <TextBlock Text="{Binding IsDarkTheme, Converter={StaticResource BoolToTextConverter}, ConverterParameter=🌙|☀️}" 
                       FontSize="20"/>
        </Button>
    </Grid>
</Window>
