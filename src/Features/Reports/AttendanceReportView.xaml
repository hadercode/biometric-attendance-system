<UserControl x:Class="LectorHuellas.Features.Reports.AttendanceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Reporte de Asistencia" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Consulte los registros de entrada y salida del personal"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ Filters ═══ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Filtros" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <WrapPanel>
                    <!-- Quick Filters -->
                    <Button Style="{StaticResource SecondaryButton}" Content="📅 Hoy"
                            Command="{Binding FilterTodayCommand}" Margin="0,0,8,8" Padding="12,8"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="📅 Esta Semana"
                            Command="{Binding FilterWeekCommand}" Margin="0,0,8,8" Padding="12,8"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="📅 Este Mes"
                            Command="{Binding FilterMonthCommand}" Margin="0,0,8,8" Padding="12,8"/>
                </WrapPanel>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Desde" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="160"
                                    Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hasta" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="160"
                                    Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <Button Grid.Column="4" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}" VerticalAlignment="Bottom"
                            Content="🔍 Buscar" Padding="16,10"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ Stats Summary ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TotalRecords}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryLightBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Registros" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CheckInCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Entradas" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CheckOutCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Salidas" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ Records Table ═══ -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Records}"
                      ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}"
                      CellStyle="{StaticResource ModernDataGridCell}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding Timestamp, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                    <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="100"/>
                    <DataGridTextColumn Header="Empleado" Binding="{Binding Employee.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding Employee.Code}" Width="140"/>
                    <DataGridTemplateColumn Header="Tipo" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="CheckIn">
                                                    <Setter Property="Background" Value="#1A00B894"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="CheckOut">
                                                    <Setter Property="Background" Value="#1A00CEC9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="CheckIn">
                                                        <Setter Property="Text" Value="✅ Entrada"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="CheckOut">
                                                        <Setter Property="Text" Value="🚪 Salida"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
