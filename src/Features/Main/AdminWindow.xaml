<Window x:Class="LectorHuellas.Features.Main.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:main="clr-namespace:LectorHuellas.Features.Main"
        xmlns:dashboard="clr-namespace:LectorHuellas.Features.Dashboard"
        xmlns:employees="clr-namespace:LectorHuellas.Features.Employees"
        xmlns:reports="clr-namespace:LectorHuellas.Features.Reports"
        xmlns:settings="clr-namespace:LectorHuellas.Features.Settings"
        xmlns:conv="clr-namespace:LectorHuellas.Shared.Converters"
        xmlns:ctrl="clr-namespace:LectorHuellas.Shared.Controls"
        Title="Panel de Administración — Control de Asistencia"
        Width="1280" Height="800" MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDarkBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource BgCardBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel>
                <!-- Logo / Header -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Área Admin" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Gestión de Asistencia" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

                        <TextBlock Text="{Binding UserDisplayName}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>

                        <!-- Device Status -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Border CornerRadius="8" Padding="10,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1A00CEC9"/> <!-- Accent-ish -->
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScannerDetected}" Value="False">
                                                <Setter Property="Background" Value="#1AFF7675"/> <!-- Danger-ish -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding DeviceStatus}" FontSize="11" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScannerDetected}" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            
                            <!-- Retry Button -->
                            <Button Command="{Binding RetryScannerDetectionCommand}"
                                    Width="30" Height="28" Margin="8,0,0,0"
                                    Background="{DynamicResource BgSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    ToolTip="Reintentar detección del lector"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <TextBlock Text="🔄" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BorderBrush}" Margin="16,0"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="12,16">
                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StringMatchConverter}, ConverterParameter=Dashboard, Mode=OneWay}"
                                 Command="{Binding NavigateToPageCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StringMatchConverter}, ConverterParameter=Employees, Mode=OneWay}"
                                 Command="{Binding NavigateToPageCommand}" CommandParameter="Employees">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Empleados" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource StringMatchConverter}, ConverterParameter=Settings, Mode=OneWay}"
                                 Command="{Binding NavigateToPageCommand}" CommandParameter="Settings"
                                 Visibility="{Binding CanConfigureSettings, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Theme Toggle & Logout -->
                <Border DockPanel.Dock="Bottom" Padding="12,12">
                    <StackPanel>
                        <Button Style="{StaticResource ThemeToggleButton}" 
                                Command="{Binding ToggleThemeCommand}"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IsDarkTheme, Converter={StaticResource BoolToTextConverter}, ConverterParameter=🌙|☀️}" 
                                           FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IsDarkTheme, Converter={StaticResource BoolToTextConverter}, ConverterParameter=Modo Oscuro|Modo Claro}" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Style="{StaticResource SecondaryButton}" 
                                Command="{Binding LogoutCommand}"
                                Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" Margin="0,0,8,0"/>
                                <TextBlock Text="Cerrar Administración"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>



                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ═══ Admin Content Area ═══ -->
        <Grid Grid.Column="1" Background="{DynamicResource BgDarkBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0">
                <!-- Dashboard -->
                <dashboard:DashboardView DataContext="{Binding DashboardVM}"
                                     Visibility="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window},
                                                   Converter={StaticResource PageVisConverter}, ConverterParameter=Dashboard}"/>

                <!-- Employee List -->
                <employees:EmployeeListView DataContext="{Binding EmployeeListVM}"
                                        Visibility="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window},
                                                     Converter={StaticResource PageVisConverter}, ConverterParameter=Employees}"/>

                <!-- Employee Form -->
                <employees:EmployeeFormView DataContext="{Binding EmployeeFormVM}"
                                        Visibility="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window},
                                                     Converter={StaticResource PageVisConverter}, ConverterParameter=EmployeeForm}"/>

                <!-- Reports -->
                <reports:AttendanceReportView DataContext="{Binding AttendanceReportVM}"
                                            Visibility="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window},
                                                         Converter={StaticResource PageVisConverter}, ConverterParameter=Reports}"/>

                <!-- Settings -->
                <settings:SettingsView DataContext="{Binding SettingsVM}"
                                    Visibility="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window},
                                                 Converter={StaticResource PageVisConverter}, ConverterParameter=Settings}"/>
            </Grid>

            <!-- Footer -->
            <ctrl:AppFooter Grid.Row="1" Margin="0,0,0,10"/>
        </Grid>
    </Grid>
</Window>
