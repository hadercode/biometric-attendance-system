<UserControl x:Class="LectorHuellas.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="700">

            <!-- Header -->
            <TextBlock Text="⚙️ Configuración de Base de Datos" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- ═══ Provider Selector ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Proveedor de Base de Datos" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Seleccione el proveedor" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider}"
                              FontSize="14" Padding="12,8"
                              Background="#2D333B" Foreground="#E6EDF3"
                              BorderBrush="#444C56" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <!-- ═══ SQLite Settings ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16"
                    Visibility="{Binding ShowSqliteFields, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="🗃️ SQLite — Configuración" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Base de datos local, no requiere servidor externo."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Ruta del archivo" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding SqlitePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <!-- ═══ Server Settings (PostgreSQL / MySQL) ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16"
                    Visibility="{Binding ShowServerFields, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <TextBlock.Text>
                            <Binding Path="SelectedProvider" StringFormat="🖥️ {0} — Configuración"/>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Text="Requiere un servidor de base de datos instalado y en ejecución."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Host -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host / Servidor" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Port -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Puerto" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Database Name -->
                    <TextBlock Text="Nombre de la base de datos" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Username -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Usuario" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Contraseña" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="PasswordBox" FontSize="14" Padding="12,8"
                                         Background="#2D333B" Foreground="#E6EDF3"
                                         BorderBrush="#444C56" BorderThickness="1"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Status Message ═══ -->
            <TextBlock FontSize="13" Margin="0,0,0,16" TextWrapping="Wrap">
                <TextBlock.Foreground>
                    <SolidColorBrush Color="{Binding StatusColor}"/>
                </TextBlock.Foreground>
                <TextBlock.Text>
                    <Binding Path="StatusMessage"/>
                </TextBlock.Text>
            </TextBlock>

            <!-- ═══ Action Buttons ═══ -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="🔌 Probar Conexión"
                        Command="{Binding TestConnectionCommand}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="💾 Guardar Configuración"
                        Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
