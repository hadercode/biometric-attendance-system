<UserControl x:Class="LectorHuellas.Views.EmployeeFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LectorHuellas.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="700">

            <!-- Header -->
            <TextBlock Text="{Binding FormTitle}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- ═══ Form Card ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Información del Empleado" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <!-- Full Name -->
                    <TextBlock Text="Nombre Completo" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Document ID -->
                    <TextBlock Text="Cédula de Identidad" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding DocumentId, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"/>
                </StackPanel>
            </Border>

            <!-- ═══ Fingerprint Card ═══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Registro de Huella" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock FontSize="13" Margin="0,0,0,16">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding CaptureStatusColor}"/>
                            </TextBlock.Foreground>
                            <TextBlock.Text>
                                <Binding Path="CaptureStatus"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding CaptureFingerprintCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👆" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Capturar Huella" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Fingerprint Preview -->
                    <Border Grid.Column="1" Width="160" Height="200" CornerRadius="12"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderThickness="2" BorderBrush="{StaticResource BorderBrush}"
                            Margin="20,0,0,0">
                        <Grid>
                            <TextBlock Text="👆" FontSize="40" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.2"/>
                            <Image Source="{Binding FingerprintImage}" Stretch="Uniform" Margin="8"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ Validation ═══ -->
            <TextBlock Text="{Binding ValidationMessage}" FontSize="13"
                       Foreground="{StaticResource DangerBrush}" Margin="0,0,0,12"
                       Visibility="{Binding ValidationMessage, Converter={StaticResource NotEmptyToVisConverter}}"/>

            <!-- ═══ Action Buttons ═══ -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Cancelar"
                        Command="{Binding CancelCommand}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="💾 Guardar Empleado"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
