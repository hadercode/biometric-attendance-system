<UserControl x:Class="LectorHuellas.Views.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LectorHuellas.ViewModels">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Empleados" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Administre los empleados registrados en el sistema"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.NewEmployeeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Empleado" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"
                        Content="🔄 Actualizar"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══ Employee Table ═══ -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}"
                      CellStyle="{StaticResource ModernDataGridCell}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Nombre Completo" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Cédula" Binding="{Binding DocumentId}" Width="150"/>
                    <DataGridTemplateColumn Header="Huella" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FingerprintTemplate, Converter={StaticResource HasValueConverter}}"
                                           FontSize="16" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Registro" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                    <DataGridTemplateColumn Header="Acciones" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️ Editar" Style="{StaticResource SecondaryButton}"
                                            Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                            Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                    <Button Content="🗑️" Style="{StaticResource DangerButton}"
                                            Padding="8,4" FontSize="11"
                                            Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
